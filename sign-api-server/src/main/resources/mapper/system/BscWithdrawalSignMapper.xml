<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.BscWithdrawalSignMapper">

    <resultMap type="com.ruoyi.system.domain.BscWithdrawalSign" id="BscWithdrawalSignResult">
        <result property="id" column="id"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="createBy" column="create_by"/>
        <result property="updateBy" column="update_by"/>
        <result property="flag" column="flag"/>
        <result property="withdrawLogId" column="withdraw_log_id"/>
        <result property="signerAddress" column="signer_address"/>
        <result property="signDigest" column="sign_digest"/>
        <result property="signature" column="signature"/>
        <result property="signStatus" column="sign_status"/>
        <result property="signStep" column="sign_step"/>
        <result property="signServer" column="sign_server"/>
        <result property="remark" column="remark"/>
        <result property="signTime" column="sign_time"/>
        <result property="orderId" column="order_id"/>
        <result property="deadline" column="deadline"/>
        <result property="userNonce" column="user_nonce"/>
        <result property="bizId" column="biz_id"/>
        <result property="failReason" column="fail_reason"/>
    </resultMap>

    <sql id="selectBscWithdrawalSignVo">
        select id, create_time, update_time, create_by, update_by, flag,
               withdraw_log_id, signer_address, sign_digest, signature,
               sign_status, sign_step, sign_server, remark, sign_time,
               order_id, deadline, user_nonce, biz_id, fail_reason
        from bsc_withdrawal_sign
    </sql>

    <select id="selectBscWithdrawalSignList" parameterType="com.ruoyi.system.domain.BscWithdrawalSign"
            resultMap="BscWithdrawalSignResult">
        <include refid="selectBscWithdrawalSignVo"/>
        <where>
            and flag = 0
            <if test="withdrawLogId != null">
                and withdraw_log_id = #{withdrawLogId}
            </if>
            <if test="signerAddress != null and signerAddress != ''">
                and signer_address = #{signerAddress}
            </if>
            <if test="signStatus != null">
                and sign_status = #{signStatus}
            </if>
            <if test="signStep != null">
                and sign_step = #{signStep}
            </if>
            <if test="signServer != null and signServer != ''">
                and sign_server = #{signServer}
            </if>
            <if test="orderId != null and orderId != ''">
                and order_id = #{orderId}
            </if>
            <if test="params.beginTime != null and params.beginTime != '' and params.endTime != null and params.endTime != ''">
                and create_time between #{params.beginTime} and #{params.endTime}
            </if>
        </where>
        order by id desc
    </select>

    <select id="selectBscWithdrawalSignById" parameterType="integer" resultMap="BscWithdrawalSignResult">
        <include refid="selectBscWithdrawalSignVo"/>
        where id = #{id}
        and flag = 0
    </select>

    <select id="getByWithdrawLogIdAndStep" resultMap="BscWithdrawalSignResult">
        <include refid="selectBscWithdrawalSignVo"/>
        where withdraw_log_id = #{withdrawLogId}
        and sign_step = #{signStep}
        and flag = 0
        limit 1
    </select>

    <insert id="insert" parameterType="com.ruoyi.system.domain.BscWithdrawalSign" useGeneratedKeys="true" keyProperty="id">
        insert into bsc_withdrawal_sign
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="updateBy != null and updateBy != ''">update_by,</if>
            <if test="flag != null">flag,</if>
            <if test="withdrawLogId != null">withdraw_log_id,</if>
            <if test="signerAddress != null and signerAddress != ''">signer_address,</if>
            <if test="signDigest != null and signDigest != ''">sign_digest,</if>
            <if test="signature != null and signature != ''">signature,</if>
            <if test="signStatus != null">sign_status,</if>
            <if test="signStep != null">sign_step,</if>
            <if test="signServer != null and signServer != ''">sign_server,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="signTime != null">sign_time,</if>
            <if test="orderId != null and orderId != ''">order_id,</if>
            <if test="deadline != null">deadline,</if>
            <if test="userNonce != null">user_nonce,</if>
            <if test="bizId != null">biz_id,</if>
            <if test="failReason != null and failReason != ''">fail_reason,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="updateBy != null and updateBy != ''">#{updateBy},</if>
            <if test="flag != null">#{flag},</if>
            <if test="withdrawLogId != null">#{withdrawLogId},</if>
            <if test="signerAddress != null and signerAddress != ''">#{signerAddress},</if>
            <if test="signDigest != null and signDigest != ''">#{signDigest},</if>
            <if test="signature != null and signature != ''">#{signature},</if>
            <if test="signStatus != null">#{signStatus},</if>
            <if test="signStep != null">#{signStep},</if>
            <if test="signServer != null and signServer != ''">#{signServer},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="signTime != null">#{signTime},</if>
            <if test="orderId != null and orderId != ''">#{orderId},</if>
            <if test="deadline != null">#{deadline},</if>
            <if test="userNonce != null">#{userNonce},</if>
            <if test="bizId != null">#{bizId},</if>
            <if test="failReason != null and failReason != ''">#{failReason},</if>
        </trim>
    </insert>

    <update id="updateById" parameterType="com.ruoyi.system.domain.BscWithdrawalSign">
        update bsc_withdrawal_sign
        <set>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="flag != null">flag = #{flag},</if>
            <if test="withdrawLogId != null">withdraw_log_id = #{withdrawLogId},</if>
            <if test="signerAddress != null and signerAddress != ''">signer_address = #{signerAddress},</if>
            <if test="signDigest != null and signDigest != ''">sign_digest = #{signDigest},</if>
            <if test="signature != null and signature != ''">signature = #{signature},</if>
            <if test="signStatus != null">sign_status = #{signStatus},</if>
            <if test="signStep != null">sign_step = #{signStep},</if>
            <if test="signServer != null and signServer != ''">sign_server = #{signServer},</if>
            <if test="remark != null and remark != ''">remark = #{remark},</if>
            <if test="signTime != null">sign_time = #{signTime},</if>
            <if test="orderId != null and orderId != ''">order_id = #{orderId},</if>
            <if test="deadline != null">deadline = #{deadline},</if>
            <if test="userNonce != null">user_nonce = #{userNonce},</if>
            <if test="bizId != null">biz_id = #{bizId},</if>
            <if test="failReason != null and failReason != ''">fail_reason = #{failReason},</if>
        </set>
        where id = #{id}
    </update>

    <update id="updateByWithdrawLogIdAndStep" parameterType="com.ruoyi.system.domain.BscWithdrawalSign">
        update bsc_withdrawal_sign
        <set>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="signStatus != null">sign_status = #{signStatus},</if>
            <if test="signature != null and signature != ''">signature = #{signature},</if>
            <if test="signTime != null">sign_time = #{signTime},</if>
            <if test="failReason != null and failReason != ''">fail_reason = #{failReason},</if>
        </set>
        where withdraw_log_id = #{withdrawLogId}
        and sign_step = #{signStep}
        and flag = 0
    </update>


    <select id="countSuccessSign" resultType="long">
        select count(1)
        from bsc_withdrawal_sign
        where flag = 0
          and withdraw_log_id = #{withdrawLogId}
          and sign_step = #{signStep}
          and sign_server = #{signServer}
    </select>


    <select id="countByWithdrawLogIdAndDigest" resultType="long">
        select count(1)
        from bsc_withdrawal_sign
        where flag = 0
          and withdraw_log_id = #{withdrawLogId}
          and sign_digest = #{signDigest}
          and sign_status = 2
    </select>
</mapper>